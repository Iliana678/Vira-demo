# ══════════════════════════════════════════════════════════════════════════════
# VIRA · .gitignore — 绝不把密钥和本地垃圾推到 GitHub
# ══════════════════════════════════════════════════════════════════════════════

# ── 🔑 密钥 / 环境变量（最高优先级）─────────────────────────────────────────
.env
.env.*
!.env.example          # 只保留示例文件（无真实值）
*.pem
*.key
secrets.toml
.streamlit/secrets.toml

# ── Python 缓存 ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── 虚拟环境 ────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── 数据库 / 本地持久化数据（云端应使用外部存储）───────────────────────────
data/*.db
data/templates/
# 保留 data/__init__.py（代码文件）
!data/__init__.py

# ── 构建产物 ────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ── 编辑器 / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── 日志 / 临时文件 ──────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
/tmp/

# ── 测试视频 / 大型媒体文件（避免撑大 repo）─────────────────────────────────
*.mp4
*.mov
*.avi
*.webm
*.mkv
*.mp3
*.wav
*.m4a
test_videos/
sample_videos/

# ── Streamlit 本地快照 ────────────────────────────────────────────────────────
localhost_*.json

# ── 其他项目遗留 ─────────────────────────────────────────────────────────────
.dev.vars
.wrangler/
node_modules/

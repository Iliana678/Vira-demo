# ── Streamlit Community Cloud Secrets 模板 ───────────────────────────────────
# 使用方法：
#   1. 登录 share.streamlit.io → 你的 App → Settings → Secrets
#   2. 把下方内容（去掉注释）粘贴进去，填入真实值
#   3. 本文件（*.example）可安全上传 GitHub；secrets.toml 本身已被 .gitignore 排除
#
# 代码读取方式：
#   import streamlit as st
#   api_key = st.secrets["OPENAI_API_KEY"]
#   # 或保持 os.getenv() 写法，Streamlit Cloud 会自动把 secrets 注入环境变量

[default]
OPENAI_API_KEY = "sk-..."

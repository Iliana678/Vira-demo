# ── Streamlit Community Cloud Secrets 模板 ───────────────────────────────────
# 使用方法：
#   1. 登录 share.streamlit.io → 你的 App → Settings → Secrets
#   2. 把下方内容（去掉注释）粘贴进去，填入真实值
#   3. 本地开发：复制为 .streamlit/secrets.toml（已被 .gitignore 排除）
#
# 三个 Key 全部必填，缺任何一个 app 都无法正常运行

[default]
# OpenAI API Key（GPT-4o Vision + Whisper）
OPENAI_API_KEY = "sk-..."

# 管理员邮箱（登录后侧边栏出现管理后台入口）
ADMIN_EMAIL = "your@email.com"

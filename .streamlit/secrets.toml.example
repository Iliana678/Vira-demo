# ── Streamlit Community Cloud Secrets 模板 ───────────────────────────────────
# 使用方法：
#   1. 登录 share.streamlit.io → 你的 App → Settings → Secrets
#   2. 把下方内容（去掉注释）粘贴进去，填入真实值
#   3. 本地开发：复制本文件为 .streamlit/secrets.toml 并填入真实值
#      （secrets.toml 已被 .gitignore 排除，永远不会提交到 Git）
#   4. 本文件（*.example）只含占位符，可以安全上传 GitHub

# ── OpenAI ───────────────────────────────────────────────────────────────────
# 代码读取方式：st.secrets["openai"]["api_key"]
[openai]
api_key = "sk-..."        # 替换为你的 OpenAI API Key（sk-proj-... 或 sk-...）
model   = "gpt-4o"        # 默认模型：gpt-4o / gpt-4o-mini

# ── Gemini ───────────────────────────────────────────────────────────────────
# 视频分析功能（🎬 上传视频 tab）使用 Gemini 1.5 Pro
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "AIza..."       # 替换为你的 Gemini API Key

# ── 管理员配置 ────────────────────────────────────────────────────────────────
# ADMIN_EMAIL  — 该邮箱登录后侧边栏出现旧版管理工具（开通 Pro / 礼品码）
# ADMIN_PASSWORD — 侧边栏底部 ⚙ 按钮的密码，通过后进入数据分析后台
ADMIN_EMAIL    = "your@email.com"
ADMIN_PASSWORD = "change-me-to-a-strong-password"
